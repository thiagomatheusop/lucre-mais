<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Obrigado — Lucre Mais</title>
  <meta name="robots" content="noindex, nofollow" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="BRANCO.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green:      #0d5c38;
      --green-mid:  #0e6f42;
      --green-light: rgba(0, 230, 118, 0.10);
      --neon:       #00e676;
      --white:      #ffffff;
      --gray-700:   #909088;
      --gray-900:   #edede9;
      --font:       'Plus Jakarta Sans', sans-serif;
      --grad:       linear-gradient(135deg, var(--neon) 0%, var(--green) 100%);
    }

    html, body {
      height: 100%;
      font-family: var(--font);
      background: #070707;
      color: var(--gray-900);
      -webkit-font-smoothing: antialiased;
      color-scheme: dark;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ─── Header ───────────────────────────────────────────────── */
    header {
      padding: 24px 40px;
      border-bottom: 1px solid rgba(255,255,255,.06);
    }

    .logo {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--white);
      letter-spacing: -.02em;
    }
    .logo img {
      height: 32px;
      width: auto;
    }

    /* ─── Main ─────────────────────────────────────────────────── */
    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 60px 28px;
      position: relative;
      overflow: hidden;
    }

    main::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(0,230,118,.07) 0%, transparent 65%);
      pointer-events: none;
    }

    .content {
      position: relative;
      max-width: 560px;
    }

    /* Check icon */
    .check-icon {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: var(--grad);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 36px;
    }
    .check-icon svg {
      width: 34px; height: 34px;
      stroke: #0a0a0a;
      stroke-width: 2.8;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* Headline */
    h1 {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 800;
      letter-spacing: -.03em;
      line-height: 1.15;
      color: var(--gray-900);
      margin-bottom: 20px;
    }
    h1 em {
      font-style: normal;
      background: var(--grad);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Sub */
    p.sub {
      font-size: 1.05rem;
      color: var(--gray-700);
      line-height: 1.7;
      margin-bottom: 48px;
    }

    /* Divider */
    .divider {
      width: 40px;
      height: 1px;
      background: rgba(255,255,255,.1);
      margin: 0 auto 36px;
    }

    /* Instagram */
    .social-label {
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: rgba(255,255,255,.3);
      margin-bottom: 16px;
    }

    .instagram-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: var(--gray-900);
      font-size: .95rem;
      font-weight: 600;
      padding: 12px 22px;
      border-radius: 99px;
      border: 1px solid rgba(255,255,255,.1);
      transition: border-color .3s ease, background .3s ease, transform .3s ease;
    }
    .instagram-link:hover {
      border-color: rgba(255,255,255,.25);
      background: rgba(255,255,255,.04);
      transform: translateY(-1px);
    }
    .instagram-link svg {
      width: 20px; height: 20px;
      flex-shrink: 0;
    }

    /* ─── Footer ───────────────────────────────────────────────── */
    footer {
      padding: 24px 40px;
      border-top: 1px solid rgba(255,255,255,.05);
      text-align: center;
      font-size: .8rem;
      color: rgba(255,255,255,.25);
    }
  </style>
</head>

<body>

  <!-- Header -->
  <header>
    <a href="/" class="logo">
      Lucre Mais
    </a>
  </header>

  <!-- Main -->
  <main>
    <div class="content">

      <div class="check-icon">
        <svg viewBox="0 0 24 24">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <h1>Obrigado pelo<br />seu <em>interesse!</em></h1>

      <p class="sub">
        Em breve nossa equipe entrará em<br />contato com você por WhatsApp ou ligação.
      </p>

      <div class="divider"></div>

      <p class="social-label">Nos acompanhe nas redes</p>

      <a href="https://instagram.com/lucremaishub_" target="_blank" rel="noopener" class="instagram-link">
        <!-- Instagram SVG icon -->
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="url(#ig-grad)" stroke-width="2"/>
          <circle cx="12" cy="12" r="4" stroke="url(#ig-grad)" stroke-width="2"/>
          <circle cx="17.5" cy="6.5" r="1" fill="url(#ig-grad)"/>
          <defs>
            <linearGradient id="ig-grad" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#f9ce34"/>
              <stop offset="50%" stop-color="#ee2a7b"/>
              <stop offset="100%" stop-color="#6228d7"/>
            </linearGradient>
          </defs>
        </svg>
        @lucremaishub_
      </a>

    </div>
  </main>

  <!-- Footer -->
  <footer>
    © 2025 Lucre Mais. Todos os direitos reservados.
  </footer>

</body>
</html>
